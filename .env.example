# ConvoCore Configuration
WORKSPACE_SECRET=your_workspace_secret_here

# Optional: Choose API region (eu-gcp or na-gcp)
CONVOCORE_API_REGION=eu-gcp

# Optional: Full REST base URL override (overrides region when set).
# Use for local debug, e.g. http://localhost:5000/v3
# CONVOCORE_API_BASE_URL=http://localhost:5000/v3

# Optional: Override ONLY the /interact WebSocket URL.
# Use when you want REST on prod but WebSocket on a local dev server.
# Example: ws://localhost:5000/interact
# CONVOCORE_INTERACT_WS_URL=ws://localhost:5000/interact

# Used by `pnpm publish:npm` — needs Publish permission for convocore-mcp (Automation token).
NPM_ACCESS_TOKEN=

# --- Hosted Streamable HTTP server (dist/hosted.js / Dockerfile.hosted) ---
# PORT=3009
# HOST=0.0.0.0
# MCP_HTTP_PATH=/mcp
# CONVOCORE_HOSTED_ALLOWED_HOSTS=mcp.convocore.ai
# CONVOCORE_HOSTED_DNS_PROTECTION=true
